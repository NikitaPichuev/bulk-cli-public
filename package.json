{
  "name": "bulk-cli",
  "version": "0.1.0",
  "description": "Minimal TypeScript CLI for Bulk testnet perp trading via direct API and agent wallet.",
  "main": "dist/cli.js",
  "bin": {
    "bulk-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "derive-seeds": "tsx src/deriveSolanaKeys.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "bulk",
    "perps",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "bulk-keychain": "^0.1.8",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ed25519-hd-key": "^1.3.0",
    "tweetnacl": "^1.0.3",
    "undici": "^7.24.5"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
